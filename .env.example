# SeismicLog environment configuration.
# Copy to `.env`; every variable is optional. With nothing set, the
# app runs fully offline using seeded data and the local template
# fallback for the LLM briefing.

# --- LLM providers ---------------------------------------------------
# Primary provider. If unset, OpenRouter is skipped.
# OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Secondary provider. If unset, Anthropic is skipped.
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Behaviour -------------------------------------------------------
# Force the seed-only path and the template LLM fallback, regardless
# of whether keys / network are present. Useful for demos.
DEMO_OFFLINE=0

# --- Runtime ---------------------------------------------------------
FLASK_ENV=production
PORT=8002

# Override the default SQLite location. Default points at
# /app/data/seismiclog.db inside the container.
# DATABASE_URL=sqlite:////app/data/seismiclog.db
